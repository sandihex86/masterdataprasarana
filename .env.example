APP_NAME="Master Data API Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Default tetap kompatibel dengan koneksi utama aplikasi.
# Untuk mode bounded context enterprise, Anda bisa mengganti ke `core`.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=prasarana
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

CORE_DB_CONNECTION=mysql
CORE_DB_HOST=127.0.0.1
CORE_DB_PORT=3306
CORE_DB_DATABASE=prasarana_core
CORE_DB_USERNAME=root
CORE_DB_PASSWORD=
CORE_DB_CHARSET=utf8mb4
CORE_DB_COLLATION=utf8mb4_unicode_ci
CORE_DB_SSL_CA=

REFERENCE_DB_CONNECTION=mysql
REFERENCE_DB_HOST=127.0.0.1
REFERENCE_DB_PORT=3306
REFERENCE_DB_DATABASE=prasarana_reference
REFERENCE_DB_USERNAME=root
REFERENCE_DB_PASSWORD=
REFERENCE_DB_CHARSET=utf8mb4
REFERENCE_DB_COLLATION=utf8mb4_unicode_ci
REFERENCE_DB_SSL_CA=

BRIDGE_DB_CONNECTION=mysql
BRIDGE_DB_HOST=127.0.0.1
BRIDGE_DB_PORT=3306
BRIDGE_DB_DATABASE=prasarana_bridge
BRIDGE_DB_USERNAME=root
BRIDGE_DB_PASSWORD=
BRIDGE_DB_CHARSET=utf8mb4
BRIDGE_DB_COLLATION=utf8mb4_unicode_ci
BRIDGE_DB_SSL_CA=


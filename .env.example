TRACK_DB_HOST=127.0.0.1
TRACK_DB_PORT=3306
TRACK_DB_DATABASE=prasarana_track
TRACK_DB_USERNAME=root
TRACK_DB_PASSWORD=
TRACK_DB_CHARSET=utf8mb4
TRACK_DB_COLLATION=utf8mb4_unicode_ci
TRACK_DB_SSL_CA=

OPERATIONAL_FACILITY_DB_CONNECTION=mysql
OPERATIONAL_FACILITY_DB_HOST=127.0.0.1
OPERATIONAL_FACILITY_DB_PORT=3306
OPERATIONAL_FACILITY_DB_DATABASE=prasarana_operational_facility
OPERATIONAL_FACILITY_DB_USERNAME=root
OPERATIONAL_FACILITY_DB_PASSWORD=
OPERATIONAL_FACILITY_DB_CHARSET=utf8mb4
OPERATIONAL_FACILITY_DB_COLLATION=utf8mb4_unicode_ci

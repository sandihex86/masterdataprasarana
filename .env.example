CERTIFICATE_DB_COLLATION=utf8mb4_unicode_ci
CERTIFICATE_DB_SSL_CA=

WAREHOUSE_DB_CONNECTION=mysql
WAREHOUSE_DB_HOST=127.0.0.1
WAREHOUSE_DB_PORT=3306
WAREHOUSE_DB_DATABASE=prasarana_warehouse
WAREHOUSE_DB_USERNAME=root
WAREHOUSE_DB_PASSWORD=
WAREHOUSE_DB_CHARSET=utf8mb4
WAREHOUSE_DB_COLLATION=utf8mb4_unicode_ci

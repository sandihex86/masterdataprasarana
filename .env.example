MASTER_DATA_DEFAULT_PER_PAGE=25
MASTER_DATA_MAX_PER_PAGE=100
MASTER_DATA_IMPORT_CHUNK_SIZE=1000
MASTER_DATA_MAPPING_PREVIEW_LIMIT=10
MASTER_DATA_CACHE_ENABLED=true
MASTER_DATA_CACHE_TTL=300

API_DEFAULT_RATE_LIMIT_PER_MINUTE=60
API_DEFAULT_RATE_LIMIT_PER_DAY=10000
API_LOG_RETENTION_DAYS=90
IMPORT_FILE_RETENTION_DAYS=30
IMPORT_ERROR_RETENTION_DAYS=180

SWAGGER_ENABLED=true
SWAGGER_REQUIRE_AUTH=true
L5_SWAGGER_GENERATE_ALWAYS=true
L5_SWAGGER_TRUSTED_PROXIES=*

MASTER_DATA_BRIDGE_SOURCE_CONNECTION=bridge

VITE_APP_NAME="${APP_NAME}"
